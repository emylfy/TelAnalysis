# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
.pytest_cache/

# User-generated assets (chats, exports, graphs, csvs, wordclouds)
asset/

# Demo JSON exports (tools/gen_demo_data.py). The two canonical demos are committed —
# the Try-demo buttons and the Docker image load them; other local exports stay ignored.
demo/*.json
!demo/personal_demo.json
!demo/group_demo.json

# Local config (may contain user-specific overrides)
config.json

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Frontend build artifacts / deps (built by run.sh; frontend/.gitignore also covers these)
frontend/node_modules/
frontend/dist/

# nltk data (downloaded at first run)
nltk_data/
.ruff_cache/
.playwright-mcp/
# Top-level screenshots/ from ad-hoc dev sessions. docs/screenshots/ is tracked.
/screenshots/
frontend/.vite/
